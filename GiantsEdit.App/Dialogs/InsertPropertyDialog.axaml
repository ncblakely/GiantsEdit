<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GiantsEdit.App.Dialogs.InsertPropertyDialog"
        Title="Insert World Property" Width="400" Height="450"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <TextBox x:Name="TxtFilter" DockPanel.Dock="Top" Watermark="Search..." Margin="0,0,0,8" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,8,0,0">
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" />
            <Button x:Name="BtnOk" Content="Insert" Width="80" />
        </StackPanel>
        <ListBox x:Name="PropertyList" />
    </DockPanel>
</Window>
