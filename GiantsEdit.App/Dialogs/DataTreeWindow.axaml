<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dlg="using:GiantsEdit.App.Dialogs"
        x:Class="GiantsEdit.App.Dialogs.DataTreeWindow"
        x:DataType="dlg:DataTreeWindow"
        Title="World Objects Tree View" Width="700" Height="550"
        WindowStartupLocation="CenterOwner">
    <DockPanel>
        <!-- Status bar -->
        <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom"
                   Padding="8,4"
                   Text="Select a node to view its properties" />

        <!-- Main split: tree left, properties right -->
        <Grid ColumnDefinitions="*,4,300">
            <!-- Tree -->
            <TreeView x:Name="DataTree" Grid.Column="0" Margin="4">
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="MnuInsertProperty" Header="Insert Property..." />
                    </ContextMenu>
                </TreeView.ContextMenu>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate x:DataType="dlg:DataTreeNodeVm"
                                      ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" />
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <GridSplitter Grid.Column="1" Width="4" />

            <!-- Properties panel -->
            <Border Grid.Column="2" BorderThickness="1,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Properties"
                               FontWeight="Bold" Margin="8,4" />
                    <!-- Add/Remove buttons for list nodes -->
                    <StackPanel x:Name="ListEditPanel" DockPanel.Dock="Bottom"
                                Orientation="Horizontal" Margin="4"
                                IsVisible="False">
                        <Button x:Name="BtnAddEntry" Content="Add" Padding="12,4" />
                    </StackPanel>
                    <ScrollViewer>
                        <StackPanel>
                            <ItemsControl x:Name="PropertiesList" Margin="4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="dlg:LeafPropertyVm">
                                        <Grid ColumnDefinitions="Auto,120,*,Auto" Margin="0,1">
                                            <Button Grid.Column="0" Content="✕" FontSize="10"
                                                    Padding="4,2" Margin="0,0,4,0"
                                                    MinWidth="0" MinHeight="0"
                                                    IsVisible="{Binding CanDelete}"
                                                    Command="{Binding DeleteCommand}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0" />
                                            <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay}"
                                                     Padding="4,2"
                                                     IsReadOnly="{Binding IsReadOnly}" />
                                            <Button Grid.Column="3" Content="▼" Width="24" Padding="2,0"
                                                    MinWidth="0" MinHeight="0"
                                                    VerticalAlignment="Stretch"
                                                    IsVisible="{Binding IsObjectType}"
                                                    Command="{Binding BrowseCommand}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Optional-checkbox properties for <Options> nodes -->
                            <ItemsControl x:Name="OptionalPropsList" Margin="4" IsVisible="False">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="dlg:OptionalLeafVm">
                                        <Grid ColumnDefinitions="Auto,110,*,Auto" Margin="0,1">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      MinWidth="0" Padding="0" Margin="0,0,4,0"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       VerticalAlignment="Center" Margin="4,0" />
                                            <TextBox Grid.Column="2" Text="{Binding Value, Mode=TwoWay}"
                                                     Padding="4,2"
                                                     IsEnabled="{Binding IsEnabled}"
                                                     IsVisible="{Binding HasValue}" />
                                            <Button Grid.Column="3" Content="▼" Width="24" Padding="2,0"
                                                    MinWidth="0" MinHeight="0"
                                                    VerticalAlignment="Stretch"
                                                    IsVisible="{Binding ShowBrowse}"
                                                    Command="{Binding BrowseCommand}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Object type search popup (shared, positioned dynamically) -->
                            <Popup x:Name="ObjTypePopup" Placement="Bottom"
                                   MaxHeight="300" Width="280"
                                   IsLightDismissEnabled="True">
                                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="4">
                                    <StackPanel Spacing="4">
                                        <TextBox x:Name="TxtObjTypeSearch" Watermark="Search..." />
                                        <ListBox x:Name="LstObjTypes" MaxHeight="240" />
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
